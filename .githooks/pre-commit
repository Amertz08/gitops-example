#!/usr/bin/env bash
set -euo pipefail

if ! command -v golines &>/dev/null; then
  echo "pre-commit: golines not found; install with: go install github.com/segmentio/golines@latest"
  exit 1
fi

staged=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
[ -z "$staged" ] && exit 0

golines -w --max-len=100 $staged
git add $staged
